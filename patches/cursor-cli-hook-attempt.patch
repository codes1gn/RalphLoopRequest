+#!/usr/bin/env bash
+#
+# durable-request stop hook
+#
+# Reads the Cursor stop-hook JSON from stdin and decides whether to
+# auto-continue the agent with a followup_message.
+#
+# Input  (stdin):  { "conversation_id": "...", "status": "completed"|"aborted"|"error", "loop_count": N }
+# Output (stdout): { "followup_message": "..." }  OR  {}
+#
+# The agent loop continues as long as followup_message is non-empty.
+# Cursor enforces a hard cap of 5 automatic follow-ups.
+
+set -euo pipefail
+
+MAX_LOOPS=4
+
+INPUT=$(cat)
+
+STATUS=$(echo "$INPUT"  | python3 -c "import sys,json; print(json.load(sys.stdin).get('status',''))"          2>/dev/null || echo "")
+LOOP=$(echo "$INPUT"    | python3 -c "import sys,json; print(json.load(sys.stdin).get('loop_count',0))"       2>/dev/null || echo "0")
+
+if [ "$STATUS" != "completed" ]; then
+  echo '{}'
+  exit 0
+fi
+
+if [ "$LOOP" -ge "$MAX_LOOPS" ]; then
+  echo '{}'
+  exit 0
+fi
+
+SCRATCHPAD=""
+for f in ".cursor/scratchpad.md" ".cursor/durable-request-state.md"; do
+  if [ -f "$f" ]; then
+    SCRATCHPAD=$(cat "$f")
+    break
+  fi
+done
+
+if echo "$SCRATCHPAD" | grep -qi "DONE\|FINISHED\|NO_FOLLOWUP"; then
+  echo '{}'
+  exit 0
+fi
+
+cat <<'FOLLOWUP'
+{"followup_message":"[durable-request hook] Agent completed — what would you like to do next? (Type your next instruction, or say \"done\" to stop.)"}
+FOLLOWUP
