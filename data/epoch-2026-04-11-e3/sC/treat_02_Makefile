.PHONY: build test clean

# Default target
all: build

build:
	@echo "[treat_02] build: compile / bundle artifacts"
	@mkdir -p dist
	@echo "dist/" > dist/.placeholder

test:
	@echo "[treat_02] test: run automated checks"
	@test -d dist || (echo "run 'make build' first" >&2; exit 1)
	@echo "OK (placeholder)"

clean:
	@echo "[treat_02] clean: remove generated outputs"
	rm -rf dist/
